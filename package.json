{
    "name": "tamiz-pro",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "npm run dev:dev",
        "dev:dev": "node scripts/app-env.cjs dev next dev --turbopack",
        "dev:prod": "node scripts/app-env.cjs prod next dev --turbopack",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "next lint",
        "prisma:migrate": "npm run prisma:migrate:dev --",
        "prisma:migrate:dev": "node scripts/prisma-env.cjs dev migrate dev",
        "prisma:migrate:prod": "node scripts/prisma-env.cjs prod migrate deploy",
        "prisma:status:dev": "node scripts/prisma-env.cjs dev migrate status",
        "prisma:status:prod": "node scripts/prisma-env.cjs prod migrate status",
        "prisma:push": "npm run prisma:push:dev",
        "prisma:push:dev": "node scripts/prisma-env.cjs dev db push",
        "prisma:push:prod": "node scripts/prisma-env.cjs prod db push",
        "prisma:generate": "prisma generate",
        "prisma:refresh": "npm run prisma:push:dev && npm run prisma:generate",
        "prisma:studio": "npm run prisma:studio:dev",
        "prisma:studio:dev": "node scripts/prisma-env.cjs dev studio",
        "prisma:studio:prod": "node scripts/prisma-env.cjs prod studio"
    },
    "resolutions": {
        "webpack": "^5.88.2"
    },
    "dependencies": {
        "@fullcalendar/bootstrap5": "^6.1.17",
        "@fullcalendar/common": "^5.11.5",
        "@fullcalendar/core": "^6.1.17",
        "@fullcalendar/daygrid": "^6.1.18",
        "@fullcalendar/interaction": "^6.1.18",
        "@fullcalendar/react": "^6.1.18",
        "@fullcalendar/timegrid": "^6.1.18",
        "@prisma/client": "^6.15.0",
        "@types/jspdf": "^1.3.3",
        "bcrypt": "^6.0.0",
        "bootstrap": "^5.3.6",
        "bootstrap-icons": "^1.13.1",
        "date-fns": "^4.1.0",
        "dotenv": "^16.5.0",
        "file-saver": "^2.0.5",
        "formidable": "^3.5.4",
        "jsonwebtoken": "^9.0.2",
        "jspdf": "^3.0.1",
        "jspdf-autotable": "^5.0.2",
        "jszip": "^3.10.1",
        "multer": "^1.4.5-lts.2",
        "next": "15.2.8",
        "puppeteer": "^24.9.0",
        "react": "^19.0.0",
        "react-bootstrap": "^2.10.10",
        "react-bootstrap-icons": "^1.11.6",
        "react-datepicker": "^8.4.0",
        "react-dom": "^19.0.0",
        "react-select": "^5.10.2",
        "react-spinners": "^0.17.0",
        "react-toastify": "^11.0.5",
        "xlsx": "^0.18.5",
        "xlsx-js-style": "^1.2.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@types/bcrypt": "^5.0.2",
        "@types/file-saver": "^2.0.7",
        "@types/formidable": "^3.4.5",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-big-calendar": "^1.16.2",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "15.3.2",
        "prisma": "^6.15.0",
        "react-big-calendar": "^1.19.4",
        "tsx": "^4.19.4",
        "typescript": "^5"
    }
}
